<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <title>ブログ管理 - 管理画面</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <main style="max-width: 1000px; margin: 40px auto; padding: 0 20px;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <h1>📁 ブログ記事管理</h1>
            <a href="/admin/blog/create" style="padding: 10px; background: #28a745; color: white; text-decoration: none;">➕ 新規記事を書く</a>
        </div>
        <p><a href="/admin">⬅️ CRMメニューに戻る</a></p>

        <table border="1" style="width: 100%; border-collapse: collapse; margin-top: 20px;">
            <thead>
                <tr style="background: #f4f4f4;">
                    <th style="padding: 10px;">ID</th>
                    <th>タイトル</th>
                    <th>ステータス</th>
                    <th>投稿日</th>
                </tr>
            </thead>
            <tbody>
                <% posts.forEach(post => { %>
                    <tr>
                        <td style="padding: 10px; text-align: center;"><%= post.id %></td>
                        <td><strong><%= post.title %></strong></td>
                        <td style="text-align: center;">
                            <span style="padding: 3px 8px; border-radius: 3px; color: white; background: <%= post.status === 'published' ? '#28a745' : '#6c757d' %>">
                                <%= post.status === 'published' ? '公開' : '下書き' %>
                            </span>
                        </td>
                        <td style="text-align: center;"><%= post.created_at %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </main>
</body>
</html>