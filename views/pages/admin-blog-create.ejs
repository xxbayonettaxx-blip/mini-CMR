<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <title>ブログ新規投稿 - 管理画面</title>
    <link rel="stylesheet" href="/css/style.css"> </head>
<body>
    <main style="max-width: 800px; margin: 40px auto; padding: 0 20px;">
        <h1>📝 ブログ新規投稿</h1>
        <p><a href="/admin/blog">⬅️ ブログ一覧に戻る</a></p>

        <form action="/admin/blog/create" method="POST" style="display: flex; flex-direction: column; gap: 15px;">
            <div>
                <label style="display: block; font-weight: bold;">タイトル</label>
                <input type="text" name="title" required style="width: 100%; padding: 8px;">
            </div>

            <div>
                <label style="display: block; font-weight: bold;">本文</label>
                <textarea name="content" required rows="10" style="width: 100%; padding: 8px;"></textarea>
            </div>

            <div>
                <label style="display: block; font-weight: bold;">ステータス</label>
                <select name="status" style="padding: 8px;">
                    <option value="draft">下書き</option>
                    <option value="published">公開</option>
                </select>
            </div>

            <div>
                <label style="display: block; font-weight: bold;">タグ（カンマ区切り）</label>
                <input type="text" name="tags" placeholder="Node.js, 初心者, 開発日記" style="width: 100%; padding: 8px;">
            </div>

            <button type="submit" style="padding: 10px; background: #007bff; color: white; border: none; cursor: pointer;">記事を保存する</button>
        </form>
    </main>
</body>
</html>