<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <title>ブログ記事一覧 - 公式サイト</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header style="background: #343a40; color: white; padding: 20px; text-align: center;">
        <h1>🚀 TakehiroのTechブログ</h1>
        <nav><a href="/contact" style="color: #ffc107; text-decoration: none; font-weight: bold;">お問合せはこちら</a></nav>
    </header>

    <main style="max-width: 800px; margin: 40px auto; padding: 0 20px;">
        <h2>最新の記事一覧</h2>
        <hr>

        <% if (posts.length === 0) { %>
            <p>まだ投稿された記事はありません。</p>
        <% } else { %>
            <div style="display: flex; flex-direction: column; gap: 30px; margin-top: 20px;">
                <% posts.forEach(post => { %>
                    <article style="border-bottom: 1px solid #eee; padding-bottom: 20px;">
                        <h3 style="margin-bottom: 10px;">
                            <a href="/blog/<%= post.id %>" style="color: #007bff; text-decoration: none;">
                                <%= post.title %>
                            </a>
                        </h3>
                        
                        <div style="white-space: pre-wrap; color: #333; margin-bottom: 10px;"><%= post.content %></div>
                        
                        <div style="font-size: 0.85rem; color: #6c757d;">
                            📅 投稿日: <%= post.created_at %> 
                            <% if (post.tags) { %> 
                                | 🏷️ タグ: <%= post.tags %>
                            <% } %>
                        </div>
                    </article>
                <% }) %>
            </div>
        <% } %>
    </main>
</body>
</html>